APP_NAME=Olive and Oak API
APP_VERSION=1.0.0
APP_ENV=development
API_PREFIX=/api/v1
ENABLE_DOCS=true
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DB_NAME=olive_oak
DEMO_SEED_ENABLED=false
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_EMAIL=admin@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=Admin123
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
TRUSTED_HOSTS=localhost,127.0.0.1,*.localhost
SECURITY_HEADERS_ENABLED=true
GROQ_API_KEY=
GROQ_MODEL_TEXT=llama-3.1-8b-instant
GROQ_MODEL_VISION=meta-llama/llama-4-scout-17b-16e-instruct
